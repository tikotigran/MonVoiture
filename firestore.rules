rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Временно разрешаем доступ к users для администратора
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'tikjan1983@gmail.com';
      
      // Вложенные коллекции
      match /{document=**} {
        allow read, write: if request.auth != null && request.auth.token.email == 'tikjan1983@gmail.com';
      }
    }
    
    // adminUsers - разрешаем для администратора
    match /adminUsers/{userId} {
      allow read, write: if request.auth != null && request.auth.token.email == 'tikjan1983@gmail.com';
    }
    
    // Все остальные коллекции - временно разрешаем
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
